{
  "name": "@transon/editor-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Internal React UI for the Transon Visual Editor: panels, sandbox/compact modes, the EditorSession store, and the light-DOM Zelos mount (ARCHITECTURE §5.1). Engine-free; the codec + validate/execute run through the host EngineProvider in @transon/editor-core (AD-008). Not published — consumed by @transon/editor-element and (M5) @transon/editor-react.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@transon/editor-blockly": "workspace:*",
    "@transon/editor-core": "workspace:*",
    "blockly": "13.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.18.9",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "axe-core": "4.10.2",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "2.1.9"
  }
}
